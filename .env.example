# Betar network
ETHEREUM_PRIVATE_KEY=           # hex-encoded secp256k1 key for x402 payments
BOOTSTRAP_PEERS=                # comma-separated multiaddrs of Betar nodes
BETAR_DATA_DIR=~/.betar-reviewer

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=    # path to .pem file

# Agent config
AGENT_NAME=pr-reviewer
AGENT_PRICE=0.005               # USDC per review
